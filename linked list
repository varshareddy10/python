class Node:
  def __init__(self,data):
    self.data=data
    self.next=None


class LinkedList:
  def __init__(self):
    self.head=None    
  def insert(self,data):
    new_node=Node(data)
    if self.head == None:
      self.head=new_node

    else:
      temp=self.head
      while temp.next:
        temp=temp.next
      temp.next=new_node  
  def display(self):
    temp=self.head
    while temp.next:
      print(temp.data,end=" -> ")
      temp=temp.next


l=LinkedList()
l.insert(100)
l.insert(200)
l.insert(300)
l.insert(400)
l.insert(500)
l.display()
